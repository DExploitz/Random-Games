-- ── Chat commands (farmer→alts) ───────────────────────────────
-- Supports normal, /e, /system prefix. Commands:
--   stopalt        → stop alt loop
--   startalt       → start alt loop
--   saveme         → teleport alt to farmer position
--   kill {player}  → alt swarms named player
local function stripChatPrefix(msg)
	msg = msg:match("^%s*(.-)%s*$")
	msg = msg:gsub("^/e%s+", "")
	msg = msg:gsub("^/system%s+", "")
	return msg:lower()
end

-- ── Command registry ──────────────────────────────────────────
-- Each entry: { pattern, handler(speaker, args, msg) }
-- 'args' is a table of space-split tokens after the command word
-- 'msg' is the full stripped message string

local CMD_HELP = {
	"stopalt          – stop the alt loop",
	"startalt         – start the alt loop",
	"restart          – stop then immediately restart the alt loop",
	"saveme           – rescue the farmer from the void",
	"goto me          – teleport alt to the farmer",
	"kill {name}      – void-kill a specific player",
	"fling {name}     – fling a specific player",
	"follow {name}    – stick to player until 'unfollow'",
	"unfollow         – stop following",
	"spawn {n|random} – switch spawn to SafePlace index or random",
	"spawn xyz {x} {y} {z} – set spawn to exact coords",
	"mode {name}      – set attack mode (ordered/spam/custom/hit_reset/trashcan)",
	"m1delay {n}      – set M1 delay in seconds",
	"skilldel {1-4} {n} – set per-skill delay",
	"antivoid on|off  – toggle alt anti-void",
	"threatmode on|off – toggle threat response",
	"threataction fling|kill – set threat action",
	"hitreset on|off  – toggle hit+reset self",
	"status           – log current alt state",
	"where            – farmer teleports alt to their own position",
	"reset            – force reset the alt character",
	"help             – print this command list",
}

local _followThread = nil
local _followTarget = nil

local function stopFollow()
	if _followThread then task.cancel(_followThread); _followThread=nil end
	_followTarget = nil
end

local function doVoidKill(targetPlayer)
	if not targetPlayer or not targetPlayer.Character then return end
	local thrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not thrp then return end
	local tpos = thrp.Position
	local si = findGrabSkillIndex()
	if si then
		teleportFacing(tpos + Vector3.new(0,3,-3), tpos)
		task.wait(0.1); skill(si); task.wait(0.5)
		teleportTo(Vector3.new(tpos.X, -5000, tpos.Z))
	else
		for s = 1, 4 do
			teleportFacing(tpos + Vector3.new(0,3,-3), tpos)
			skill(s); task.wait(skillDelay[s])
		end
	end
end

local function doFling(targetPlayer)
	if not targetPlayer or not targetPlayer.Character then return end
	local angle = 0
	local t0 = tick()
	local startPos = targetPlayer.Character:FindFirstChild("HumanoidRootPart") and
		targetPlayer.Character.HumanoidRootPart.Position or Vector3.new(0,0,0)
	while tick()-t0 < 6 do
		local tc = targetPlayer.Character
		if not tc then break end
		local thrp2 = tc:FindFirstChild("HumanoidRootPart")
		if not thrp2 then break end
		angle = angle + math.rad(180)
		local offset = CFrame.new(thrp2.Position) * CFrame.Angles(0,angle,0) * CFrame.new(3,2,0)
		local myHrp = getHRP(); if myHrp then myHrp.CFrame = offset end
		task.wait()
	end
end

local function resolvePlayerArg(name)
	if name == "me" or name == "" or name == nil then return nil end
	return Players:FindFirstChild(name)
end

local function setSpawnByIndex(idx)
	if SafePlaces[idx] then
		State.AltSpawnPlace = SafePlaces[idx].pos
		_G.PH_SPAWN = State.AltSpawnPlace
		teleportTo(State.AltSpawnPlace)
		return SafePlaces[idx].label
	end
	return nil
end

local ATTACK_MODES = {ordered=true, spam=true, custom=true, hit_reset=true, trashcan=true}

local function handleChatCommand(speaker, rawMsg)
	if not State.ChatCmdEnabled then return end
	local wl = getResolvedTargets(State.Whitelist)
	local isWhitelisted = false
	for _, n in ipairs(wl) do if speaker.Name == n then isWhitelisted=true; break end end
	if not isWhitelisted then return end

	local msg = stripChatPrefix(rawMsg)
	local tokens = {}
	for tok in msg:gmatch("%S+") do table.insert(tokens, tok) end
	local cmd = tokens[1] or ""
	local args = {}
	for i = 2, #tokens do table.insert(args, tokens[i]) end

	log("CMD ["..speaker.Name.."]: "..msg, "ALT")

	-- ── stopalt ──────────────────────────────────────────────────
	if cmd == "stopalt" then
		if State.Running and State.Role == "Alt" then stopAltLoop() end
		uiStatus("Stopped by "..speaker.Name, Color3.fromRGB(248,113,113))

	-- ── startalt ─────────────────────────────────────────────────
	elseif cmd == "startalt" then
		if not State.Running and State.Role == "Alt" then startAltLoop() end

	-- ── restart ──────────────────────────────────────────────────
	elseif cmd == "restart" then
		if State.Role == "Alt" then
			if State.Running then stopAltLoop() end
			task.wait(0.5)
			startAltLoop()
		end

	-- ── saveme ───────────────────────────────────────────────────
	elseif cmd == "saveme" then
		if speaker.Character then
			local fhrp = speaker.Character:FindFirstChild("HumanoidRootPart")
			if fhrp then
				local si = findGrabSkillIndex()
				if si then
					teleportFacing(fhrp.Position + Vector3.new(0,3,0), fhrp.Position)
					task.wait(0.1); skill(si); task.wait(0.5)
					teleportTo(State.AltSpawnPlace)
				else
					teleportTo(fhrp.Position + Vector3.new(0,4,0))
				end
			end
		end

	-- ── goto me ──────────────────────────────────────────────────
	elseif cmd == "goto" and (args[1] or "") == "me" then
		if speaker.Character then
			local fhrp = speaker.Character:FindFirstChild("HumanoidRootPart")
			if fhrp then teleportTo(fhrp.Position + Vector3.new(0,4,0)) end
		end

	-- ── kill {name} ───────────────────────────────────────────────
	elseif cmd == "kill" then
		local tp = resolvePlayerArg(args[1]) or speaker
		task.spawn(doVoidKill, tp)

	-- ── fling {name} ──────────────────────────────────────────────
	elseif cmd == "fling" then
		local tp = resolvePlayerArg(args[1]) or speaker
		local wasRunning = State.Running
		if State.Running then State.Running = false end
		task.spawn(function()
			doFling(tp)
			if wasRunning and State.Role == "Alt" then startAltLoop() end
		end)

	-- ── follow {name} ─────────────────────────────────────────────
	elseif cmd == "follow" then
		local tp = resolvePlayerArg(args[1]) or speaker
		stopFollow()
		_followTarget = tp
		local wasRunning = State.Running
		if State.Running then State.Running = false end
		_followThread = task.spawn(function()
			log("Following "..tp.Name,"ALT")
			while _followTarget == tp do
				local tc = tp.Character
				if tc then
					local thrp = tc:FindFirstChild("HumanoidRootPart")
					if thrp then
						teleportFacing(thrp.Position + Vector3.new(0,4,0), thrp.Position)
					end
				end
				task.wait()
			end
			if wasRunning and State.Role == "Alt" then startAltLoop() end
		end)

	-- ── unfollow ──────────────────────────────────────────────────
	elseif cmd == "unfollow" then
		stopFollow()
		if State.Role == "Alt" and not State.Running then startAltLoop() end

	-- ── spawn {n|random} ─────────────────────────────────────────
	elseif cmd == "spawn" then
		local sub = args[1] or ""

		if sub == "random" then
			local idx = math.random(1, #SafePlaces)
			local label = setSpawnByIndex(idx)
			log("Spawn → random → "..tostring(label).." (#"..idx..")","ALT")

		elseif sub == "xyz" then
			-- spawn xyz X Y Z
			local x,y,z = tonumber(args[2]),tonumber(args[3]),tonumber(args[4])
			if x and y and z then
				State.AltSpawnPlace = Vector3.new(x,y,z)
				_G.PH_SPAWN = State.AltSpawnPlace
				teleportTo(State.AltSpawnPlace)
				log("Spawn → custom XYZ ("..x..","..y..","..z..")","ALT")
			else
				log("spawn xyz: bad coords","WARN")
			end

		else
			local idx = tonumber(sub)
			if idx then
				local label = setSpawnByIndex(math.clamp(idx,1,#SafePlaces))
				log("Spawn → #"..idx.." ("..tostring(label)..")","ALT")
			else
				log("spawn: unknown arg '"..sub.."'","WARN")
			end
		end

	-- ── mode {name} ───────────────────────────────────────────────
	elseif cmd == "mode" then
		local m = args[1] or ""
		if ATTACK_MODES[m] then
			State.AttackMode = m
			log("Attack mode → "..m,"ALT")
		else
			log("mode: unknown '"..m.."' (ordered/spam/custom/hit_reset/trashcan)","WARN")
		end

	-- ── m1delay {n} ───────────────────────────────────────────────
	elseif cmd == "m1delay" then
		local v = tonumber(args[1])
		if v and v >= 0 then m1Delay=v; log("M1 delay → "..v.."s","ALT")
		else log("m1delay: expected a number","WARN") end

	-- ── skilldel {1-4} {n} ────────────────────────────────────────
	elseif cmd == "skilldel" then
		local idx = tonumber(args[1]); local v = tonumber(args[2])
		if idx and v and idx>=1 and idx<=4 and v>=0 then
			skillDelay[idx]=v; log("Skill "..idx.." delay → "..v.."s","ALT")
		else log("skilldel: usage  skilldel 1 0.4","WARN") end

	-- ── antivoid on|off ───────────────────────────────────────────
	elseif cmd == "antivoid" then
		local v = (args[1] or "") == "on"
		State.AltAntiVoid = v
		if v then startAltAntiVoid() else stopAltAntiVoid() end
		log("Alt anti-void → "..(v and "ON" or "OFF"),"ALT")

	-- ── threatmode on|off ─────────────────────────────────────────
	elseif cmd == "threatmode" then
		State.AltThreatMode = (args[1] or "") == "on"
		log("Threat mode → "..(State.AltThreatMode and "ON" or "OFF"),"ALT")

	-- ── threataction fling|kill ───────────────────────────────────
	elseif cmd == "threataction" then
		local a = args[1] or ""
		if a == "fling" or a == "kill" then
			State.AltThreatAction = a; log("Threat action → "..a,"ALT")
		else log("threataction: fling or kill","WARN") end

	-- ── hitreset on|off ───────────────────────────────────────────
	elseif cmd == "hitreset" then
		State.AltHitReset = (args[1] or "") == "on"
		log("Hit+Reset → "..(State.AltHitReset and "ON" or "OFF"),"ALT")

	-- ── reset ─────────────────────────────────────────────────────
	elseif cmd == "reset" then
		log("Force reset by "..speaker.Name,"ALT")
		resetCharacter()

	-- ── where ─────────────────────────────────────────────────────
	-- Teleport this alt to the farmer's current position
	elseif cmd == "where" then
		if speaker.Character then
			local fhrp = speaker.Character:FindFirstChild("HumanoidRootPart")
			if fhrp then
				State.AltSpawnPlace = fhrp.Position
				_G.PH_SPAWN = State.AltSpawnPlace
				teleportTo(State.AltSpawnPlace)
				log("Snapped to farmer position","ALT")
			end
		end

	-- ── status ───────────────────────────────────────────────────
	elseif cmd == "status" then
		local up = State.StartTime > 0 and math.floor(tick()-State.StartTime) or 0
		log(string.format("Role=%s Running=%s Mode=%s Kills=%d Uptime=%dm%ds Spawn=(%d,%d,%d)",
			tostring(State.Role), tostring(State.Running), State.AttackMode,
			State.KillCount, math.floor(up/60), up%60,
			math.floor(State.AltSpawnPlace.X),
			math.floor(State.AltSpawnPlace.Y),
			math.floor(State.AltSpawnPlace.Z)
		),"ALT")

	-- ── help ─────────────────────────────────────────────────────
	elseif cmd == "help" then
		for _, line in ipairs(CMD_HELP) do log(line,"ALT") end
	end
end

-- Hook every player's chat (needed to catch messages even with /e prefix)
