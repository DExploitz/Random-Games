-- ── Drag: grab-point preserving ───────────────────────────────
-- MainFrame always has AnchorPoint (0,0) after the initial layout snap,
-- so AbsolutePosition IS the top-left pixel. No AnchorPoint math needed.
local function makeDraggable(frame, handle)
	local dragging    = false
	local grabOffsetX = 0
	local grabOffsetY = 0

	handle.InputBegan:Connect(function(inp)
		if inp.UserInputType ~= Enum.UserInputType.MouseButton1 and
		   inp.UserInputType ~= Enum.UserInputType.Touch then return end

		-- AbsolutePosition is the true top-left pixel when AnchorPoint=(0,0)
		local tlX = frame.AbsolutePosition.X
		local tlY = frame.AbsolutePosition.Y

		-- Record which pixel of the title bar was grabbed
		grabOffsetX = inp.Position.X - tlX
		grabOffsetY = inp.Position.Y - tlY
		dragging    = true

		inp.Changed:Connect(function()
			if inp.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end)

	UserInputService.InputChanged:Connect(function(inp)
		if not dragging then return end
		if inp.UserInputType ~= Enum.UserInputType.MouseMovement and
		   inp.UserInputType ~= Enum.UserInputType.Touch then return end
		local vp = workspace.CurrentCamera.ViewportSize
		local sz = frame.AbsoluteSize
		local nx = math.clamp(inp.Position.X - grabOffsetX, 0, vp.X - sz.X)
		local ny = math.clamp(inp.Position.Y - grabOffsetY, 0, vp.Y - sz.Y)
		frame.Position = UDim2.new(0, nx, 0, ny)
	end)
end

