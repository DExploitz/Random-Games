local function parseNameBox(text)
	local raw = {}
	for n in text:gmatch("[^\n]+") do
		local t = n:match("^%s*(.-)%s*$")
		if t ~= "" then table.insert(raw, t) end
	end
	return raw
end

-- Resolve #all at call time so newly joined players are included
local function getResolvedTargets(rawList)
	local out = {}
	local hasAll = false
	for _, name in ipairs(rawList) do
		if name == "#all" then hasAll = true else table.insert(out, name) end
	end
	if hasAll then
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= plr then table.insert(out, p.Name) end
		end
	end
	return out
end

-- Threat detection: strangers near pos, excluding alts and whitelist
local function getStrangers(pos, radius)
	local out = {}
	-- Resolve whitelist (handles #all)
	local resolvedWL = getResolvedTargets(State.Whitelist)
	for _,p in ipairs(Players:GetPlayers()) do
		if p == plr then continue end
		local isAlt = false
		local resolvedAlts = getResolvedTargets(State.AltTargets)
		for _,name in ipairs(resolvedAlts) do
			if p.Name == name then isAlt = true; break end
		end
		if isAlt then continue end
		local isWL = false
		for _,name in ipairs(resolvedWL) do
			if p.Name == name then isWL = true; break end
		end
		if isWL then continue end
		local chr = p.Character
		if chr then
			local hrp = chr:FindFirstChild("HumanoidRootPart")
			if hrp and (hrp.Position - pos).Magnitude <= radius then
				table.insert(out, p.Name)
			end
		end
	end
	return out
end

local function pickSafeSpot()
	for _,place in ipairs(SafePlaces) do
		if #getStrangers(place.pos, THREAT_RADIUS) == 0 then return place.pos, place.label end
	end
	return Vector3.new(99999,100000,99999), "Secret Room (fallback)"
end

