-- ── Movement ─────────────────────────────────────────────────
local function teleportTo(pos)
	local chr=plr.Character
	if chr then
		local hrp=chr:FindFirstChild("HumanoidRootPart")
		if hrp then hrp.CFrame=CFrame.new(pos) end
	end
end

-- Teleport to myPos facing targetPos in all axes (lookAt)
local function teleportFacing(myPos, targetPos)
	local chr=plr.Character
	if chr then
		local hrp=chr:FindFirstChild("HumanoidRootPart")
		if hrp then
			-- avoid NaN if positions are identical
			if (myPos - targetPos).Magnitude > 0.01 then
				hrp.CFrame = CFrame.lookAt(myPos, targetPos)
			else
				hrp.CFrame = CFrame.new(myPos)
			end
		end
	end
end

local function teleportToCFrame(cf)
	local chr=plr.Character
	if chr then local hrp=chr:FindFirstChild("HumanoidRootPart"); if hrp then hrp.CFrame=cf end end
end

local function isAlive()
	local chr=plr.Character; if not chr then return false end
	local h=chr:FindFirstChildOfClass("Humanoid"); return h and h.Health>0
end

local function getHRP()
	local chr=plr.Character; return chr and chr:FindFirstChild("HumanoidRootPart")
end

local function resetCharacter()
	sc(function() plr.Character:FindFirstChildOfClass("Humanoid"):TakeDamage(math.huge) end)
end

local function refreshCommunicate()
	if plr.Character then
		local c=plr.Character:FindFirstChild("Communicate"); if c then communicate=c end
	end
end

local function waitForChar(timeout)
	timeout=timeout or 10; local t0=tick()
	while not isAlive() do
		if tick()-t0>timeout then log("waitForChar timeout","WARN"); return false end
		task.wait(0.2)
	end
	task.wait(0.15); refreshCommunicate(); return true
end

