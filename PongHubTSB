do
	local p = tabPages["log"]
	local c1 = card(p,1); section(c1,"Live Log",0)
	local logScroll = mk("ScrollingFrame",{
		Size=UDim2.new(1,0,0,260),BackgroundColor3=C.surface,BorderSizePixel=0,
		ScrollBarThickness=3,ScrollBarImageColor3=C.accent,
		CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
		LayoutOrder=1,
	}, c1); corner(logScroll,5); pad(logScroll,5,5,4,4); vlist(logScroll,2)

	local logLabels = {}
	local tagCols = {WARN=C.lWarn,ERR=C.lErr,THREAT=C.lErr,ALT=C.lAlt,AFK=C.lAFK,FARM=C.lFarm}
	local function addLogLine(text, tag)
		local col = tagCols[tag] or C.muted
		local ll = mk("TextLabel",{
			Text=text,TextSize=8,TextColor3=col,Font=Enum.Font.Code,
			BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),
			AutomaticSize=Enum.AutomaticSize.Y,
			TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,
		}, logScroll)
		table.insert(logLabels,1,ll)
		if #logLabels > 50 then logLabels[#logLabels]:Destroy(); table.remove(logLabels) end
		for i, ll_ in ipairs(logLabels) do ll_.LayoutOrder=i end
	end
	State.LogCB = function(text,tag) task.defer(function() pcall(addLogLine,text,tag) end) end
	for _, line in ipairs(State.LogLines) do addLogLine(line,nil) end

	local c2 = card(p,2); section(c2,"Stats",0)
	local statsLbl = mk("TextLabel",{
		Text="—",TextSize=9,TextColor3=C.text,Font=Enum.Font.Gotham,
		BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),
		AutomaticSize=Enum.AutomaticSize.Y,
		TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,TextWrapped=true,
	}, c2)
	task.spawn(function()
		while true do
			task.wait(1)
			local up = State.StartTime > 0 and math.floor(tick()-State.StartTime) or 0
			statsLbl.Text = string.format("Role: %s | Kills: %d | Uptime: %dm%ds | Mode: %s",
				State.Role or "None", State.KillCount, math.floor(up/60), up%60, State.AttackMode)
			killLbl.Text = State.KillCount .. " kills"
		end
	end)
	local clrBtn = bigBtn(c2,"Clear Log",C.surface,2,C.muted); stroke(clrBtn,C.border); clrBtn.TextSize=10
	clrBtn.MouseButton1Click:Connect(function()
		State.LogLines = {}
		for _, l in ipairs(logLabels) do l:Destroy() end; table.clear(logLabels)
	end)
end

