-- ── Watchdog ─────────────────────────────────────────────────
local _lastBeat = 0
local function beat() _lastBeat = tick() end

local function startWatchdog(restartFn)
	if State.WatchdogThread then task.cancel(State.WatchdogThread) end
	_lastBeat = tick()
	State.WatchdogThread = task.spawn(function()
		while State.Running do
			task.wait(WATCHDOG_TICK)
			if tick() - _lastBeat > 30 then
				log("Watchdog: loop frozen — restarting","WARN")
				_lastBeat = tick(); sc(restartFn)
			end
		end
	end)
end

local function stopWatchdog()
	if State.WatchdogThread then task.cancel(State.WatchdogThread); State.WatchdogThread = nil end
end

-- ── Attack functions ──────────────────────────────────────────
local function orderedAttack()
	if State.UseAwakening then awakening(); task.wait(0.2) end
	for s = 1, 4 do
		if not State.Running then return end
		for _ = 1, 4 do m1(); task.wait(m1Delay) end
		if State.OrderedDash then dash(); task.wait(dashLength) end
		skill(s); task.wait(skillDelay[s]); beat()
	end
end

local function spamAttack()
	if State.UseAwakening then awakening(); task.wait(0.15) end
	for _ = 1, 4 do
		m1(); task.wait(0.05); skill(1); task.wait(skillDelay[1])
		m1(); task.wait(0.05); skill(2); task.wait(skillDelay[2])
		m1(); task.wait(0.05); skill(3); task.wait(skillDelay[3])
		m1(); task.wait(0.05); skill(4); task.wait(skillDelay[4])
	end
	beat()
end

local function customComboAttack(combo)
	for tok in (combo..","):gmatch("([^,]+),") do
		if not State.Running then break end
		local t = tok:match("^%s*(.-)%s*$"):lower()
		if     t == "dash" then dash(); task.wait(dashLength)
		elseif t == "jump" then jump(); task.wait(0.2)
		else
			local cnt = t:match("(%d+)%s*m1")
			if cnt then
				for _ = 1, tonumber(cnt) do m1(); task.wait(m1Delay) end
			else
				local sn = t:match("^(%d+)$")
				if sn then
					local si = tonumber(sn)
					skill(si); task.wait(skillDelay[si] or stunDelay)
				end
			end
		end
	end
	beat()
end

local function hitResetAttack()
	for _ = 1, 3 do m1(); task.wait(m1Delay) end
	log("Hit x3 — waiting for alt self-reset...","FARM")
	task.wait(1.8); skill(1); task.wait(skillDelay[1]); skill(2); task.wait(skillDelay[2]); beat()
end

local function trashcanAttack(altPos)
	-- Find Workspace.Map.Trash, pick a random Trashcan model
	local mapFolder = game:GetService("Workspace"):FindFirstChild("Map")
	local trashFolder = mapFolder and mapFolder:FindFirstChild("Trash")
	if not trashFolder then log("Workspace.Map.Trash not found","WARN"); return end

	local cans = {}
	for _, v in ipairs(trashFolder:GetChildren()) do
		if v.Name == "Trashcan" then table.insert(cans, v) end
	end
	if #cans == 0 then log("No Trashcan models in Workspace.Map.Trash","WARN"); return end

	-- Find a Trashcan whose "Trashcan" instance has Transparency == 0 (visible/active)
	local pp = nil
	local tries = {}
	for _, can in ipairs(cans) do
		local part = can:FindFirstChild("Trashcan")
		if part and part:IsA("BasePart") and part.Transparency == 0 then
			table.insert(tries, part)
		end
	end
	if #tries == 0 then
		-- Fallback: use any Trashcan part regardless of transparency
		for _, can in ipairs(cans) do
			local part = can:FindFirstChild("Trashcan") or can.PrimaryPart or can:FindFirstChildOfClass("BasePart")
			if part then table.insert(tries, part) end
		end
	end
	if #tries == 0 then log("No usable Trashcan part found","WARN"); return end
	pp = tries[math.random(1, #tries)]

	-- Stand 4 studs behind the trashcan (-Z), at standing height, facing it
	local canPos   = pp.Position
	local standPos = canPos + Vector3.new(0, 4, -4)

	-- Teleport facing the trashcan → m1 → return to alt → m1 → wait
	teleportFacing(standPos, canPos)
	task.wait(0.1)
	m1()
	task.wait(m1Delay)
	teleportFacing(altPos + Vector3.new(0, 4.5, 0), altPos)
	task.wait(0.1)
	m1()
	task.wait(trashReturnWait)
	beat()
end

local function runAttack(altPos)
	local mode = State.AttackMode
	if     mode == "ordered"   then orderedAttack()
	elseif mode == "spam"      then spamAttack()
	elseif mode == "custom"    then if State.CustomCombo ~= "" then customComboAttack(State.CustomCombo) end
	elseif mode == "hit_reset" then hitResetAttack()
	elseif mode == "trashcan"  then trashcanAttack(altPos)
	end
end

-- ── Main loops ────────────────────────────────────────────────
local startFarmerLoop, stopFarmerLoop
local startAltLoop,    stopAltLoop

startFarmerLoop = function()
	if State.FarmerThread then task.cancel(State.FarmerThread) end
	State.Running = true; State.StartTime = tick()
	log("Farmer started. Targets: " .. table.concat(State.AltTargets, ", "))
	uiStatus("FARMING", Color3.fromRGB(52, 211, 153))

	if State.ThreatThread then task.cancel(State.ThreatThread) end
	State.ThreatThread = task.spawn(function()
		while State.Running do
			task.wait(WATCHDOG_TICK)
			if not State.ThreatEnabled then continue end
			if State.CurrentFarmPos then
				local s = getStrangers(State.CurrentFarmPos, THREAT_RADIUS)
				if #s > 0 and not State.ThreatDetected then
					log("Strangers near farm: " .. table.concat(s, ", "), "THREAT")
					State.ThreatDetected = true
					uiStatus("THREAT — relocating", Color3.fromRGB(251, 191, 36))
				elseif #s == 0 and State.ThreatDetected then
					log("Threat cleared","THREAT"); State.ThreatDetected = false
				end
			end
		end
	end)

	State.FarmerThread = task.spawn(function()
		-- Track which alt we're currently locked onto (index into resolvedTargets)
		local currentTargetIdx = 1

		while State.Running do
			beat()
			if State.ThreatDetected then
				local newPos, newLabel = pickSafeSpot()
				log("Relocating to: " .. newLabel, "THREAT")
				State.AltSpawnPlace = newPos; State.CurrentFarmPos = newPos; _G.PH_SPAWN = newPos
				State.ThreatDetected = false
				uiStatus("Relocated → " .. newLabel, Color3.fromRGB(52, 211, 153))
				task.wait(3); continue
			end

			if #State.AltTargets == 0 then log("No targets","WARN"); task.wait(2); continue end
			local resolvedTargets = getResolvedTargets(State.AltTargets)
			if #resolvedTargets == 0 then log("No targets resolved (#all may be empty)","WARN"); task.wait(2); continue end

			-- Clamp index in case target list shrank
			if currentTargetIdx > #resolvedTargets then currentTargetIdx = 1 end
			local targetName = resolvedTargets[currentTargetIdx]

			local tp = Players:FindFirstChild(targetName)
			if not tp then
				log("'" .. targetName .. "' not in server — advancing","WARN")
				currentTargetIdx = (currentTargetIdx % #resolvedTargets) + 1
				task.wait(1); continue
			end
			local tc = tp.Character
			if not tc then
				log(targetName .. " no character","WARN"); task.wait(2); continue
			end
			local tHRP = tc:FindFirstChild("HumanoidRootPart")
			local altHum = tc:FindFirstChildOfClass("Humanoid")
			if not tHRP or not altHum then task.wait(0.5); continue end

			-- Skip dead alts immediately — wait for respawn then continue
			if altHum.Health <= 0 then task.wait(0.3); continue end

			if not waitForChar(8) then log("Waiting to respawn","WARN"); task.wait(RECONNECT_WAIT); continue end

			-- Rapid teleport: snap to alt position + face them with no delay
			local altPos = tHRP.Position
			State.CurrentFarmPos = altPos
			local standPos = altPos + Vector3.new(0, 4.5, 0)
			teleportFacing(standPos, altPos)

			log("Attacking " .. targetName .. " [" .. State.AttackMode .. "]","FARM")
			uiStatus("Attacking " .. targetName, Color3.fromRGB(99, 102, 241))

			-- Run the attack. During the attack, a background thread keeps us
			-- snapped on top of the alt and facing them every frame.
			local trackThread = task.spawn(function()
				while State.Running do
					task.wait()  -- one-frame yield = maximum update rate
					local chr = tp.Character
					if not chr then break end
					local hrp2 = chr:FindFirstChild("HumanoidRootPart")
					if not hrp2 then break end
					local p2 = hrp2.Position
					teleportFacing(p2 + Vector3.new(0, 4.5, 0), p2)
				end
			end)

			sc(function() runAttack(altPos) end)
			task.cancel(trackThread)  -- stop tracking once attack sequence ends

			beat()

			-- Refresh humanoid after attack — check if alt died
			local altHum2 = tc:FindFirstChildOfClass("Humanoid")
			if altHum2 and altHum2.Health <= 0 then
				State.KillCount += 1
				log("Kill #" .. State.KillCount .. " on " .. targetName .. " — next alt","FARM")
				uiStatus("Kill #" .. State.KillCount, Color3.fromRGB(52, 211, 153))
				-- Advance to next alt only on confirmed kill
				currentTargetIdx = (currentTargetIdx % #resolvedTargets) + 1
			end
			-- If still alive, loop back and keep hitting the same alt
		end
		log("Farmer loop ended."); uiStatus("IDLE", Color3.fromRGB(120, 120, 160))
	end)
	startWatchdog(function() if State.Running then startFarmerLoop() end end)
	if State.FarmerAntiVoid then startFarmerAntiVoid() end
end

stopFarmerLoop = function()
	State.Running = false
	for _, k in ipairs({"FarmerThread","ThreatThread","WatchdogThread"}) do
		if State[k] then task.cancel(State[k]); State[k] = nil end
	end
	stopAntiAFK(); stopWatchdog(); stopFarmerAntiVoid()
	log("Farmer stopped."); uiStatus("IDLE", Color3.fromRGB(120, 120, 160))
end

-- ── Anti-void ─────────────────────────────────────────────────
local function startAltAntiVoid()
	if State.AltAntiVoidThread then task.cancel(State.AltAntiVoidThread) end
	State.AltAntiVoidThread = task.spawn(function()
		while State.AltAntiVoid do
			task.wait()
			local hrp = getHRP()
			if hrp and hrp.Position.Y < 0 then
				log("Alt anti-void triggered","ALT")
				while hrp and hrp.Position.Y < 0 do
					teleportTo(State.AltSpawnPlace)
					task.wait()
				end
			end
		end
	end)
end

local function stopAltAntiVoid()
	if State.AltAntiVoidThread then task.cancel(State.AltAntiVoidThread); State.AltAntiVoidThread=nil end
end

local function startFarmerAntiVoid()
	if State.FarmerAntiVoidThread then task.cancel(State.FarmerAntiVoidThread) end
	State.FarmerAntiVoidThread = task.spawn(function()
		while State.FarmerAntiVoid do
			task.wait()
			local hrp = getHRP()
			if hrp and hrp.Position.Y < 0 then
				log("Farmer anti-void triggered","FARM")
				while hrp and hrp.Position.Y < 0 do
					teleportTo(State.CurrentFarmPos or SafePlaces[1].pos)
					task.wait()
				end
			end
		end
	end)
end

local function stopFarmerAntiVoid()
	if State.FarmerAntiVoidThread then task.cancel(State.FarmerAntiVoidThread); State.FarmerAntiVoidThread=nil end
end

startAltLoop = function()
	if State.AltThread then task.cancel(State.AltThread) end
	State.Running = true; State.StartTime = tick()
	log("Alt started. Spawn: " .. tostring(State.AltSpawnPlace))
	uiStatus("ALT ACTIVE", Color3.fromRGB(139, 92, 246))
	teleportTo(State.AltSpawnPlace)

	plr.CharacterAdded:Connect(function(newChr)
		if not State.Running then return end
		newChr:WaitForChild("HumanoidRootPart", 5); task.wait(0.05)
		if _G.PH_SPAWN then State.AltSpawnPlace = _G.PH_SPAWN end
		teleportTo(State.AltSpawnPlace)
		communicate = newChr:WaitForChild("Communicate", 5) or communicate
		log("Respawned → teleported to spawn","ALT")
	end)

	State.AltThread = task.spawn(function()
		while State.Running do
			task.wait()   -- one-frame yield only, for maximum responsiveness
			beat()

			if _G.PH_SPAWN and _G.PH_SPAWN ~= State.AltSpawnPlace then
				State.AltSpawnPlace = _G.PH_SPAWN
				log("Spawn updated by farmer → moving","ALT")
			end

			local hrp = getHRP()
			if not hrp then continue end
			local myPos = hrp.Position

			-- ── Anti-void ──────────────────────────────────────────
			if State.AltAntiVoid and myPos.Y < 0 then
				log("Alt anti-void triggered","ALT")
				while getHRP() and getHRP().Position.Y < 0 do
					teleportTo(State.AltSpawnPlace); task.wait()
				end
				continue
			end

			-- ── Threat response (fling / kill) ──────────────────────
			if State.AltThreatMode and not State.AltThreatBusy then
				local ALT_THREAT_RADIUS = 50
				-- find nearest stranger
				local nearest, nearDist = nil, math.huge
				for _, p in ipairs(Players:GetPlayers()) do
					if p == plr then continue end
					local isWL = false
					for _, n in ipairs(getResolvedTargets(State.Whitelist)) do if p.Name==n then isWL=true; break end end
					if isWL then continue end
					local pc = p.Character
					if pc then
						local phrp = pc:FindFirstChild("HumanoidRootPart")
						if phrp then
							local d = (phrp.Position - myPos).Magnitude
							if d <= ALT_THREAT_RADIUS and d < nearDist then nearest=p; nearDist=d end
						end
					end
				end

				if nearest then
					State.AltThreatBusy = true
					log("Threat detected: "..nearest.Name.." ["..State.AltThreatAction.."]","ALT")
					uiStatus("Threat: "..nearest.Name, Color3.fromRGB(248,113,113))
					local savedRunning = State.Running
					State.Running = false  -- pause main loop temporarily

					local threatThread = task.spawn(function()
						if State.AltThreatAction == "fling" then
							-- FLING: stick and spin at massive angular velocity
							local startPos = myPos
							local angle = 0
							while true do
								local tc = nearest.Character
								if not tc then break end
								local thrp = tc:FindFirstChild("HumanoidRootPart")
								if not thrp then break end
								local tpos = thrp.Position
								-- Check if threat is far enough from start pos
								if (tpos - startPos).Magnitude > ALT_THREAT_RADIUS then break end
								angle = angle + math.rad(180)  -- spin very fast each frame
								local offset = CFrame.new(tpos) * CFrame.Angles(0, angle, 0) * CFrame.new(3, 2, 0)
								local hrp2 = getHRP()
								if hrp2 then hrp2.CFrame = offset end
								task.wait()
							end
						else
							-- KILL: get behind → grab skill → void kill
							local tc = nearest.Character
							if tc then
								local thrp = tc:FindFirstChild("HumanoidRootPart")
								if thrp then
									local tpos = thrp.Position
									-- Teleport rapidly behind the target
									for _ = 1, 5 do
										local behind = tpos + (thrp.CFrame.LookVector * -3) + Vector3.new(0,2,0)
										teleportFacing(behind, tpos)
										task.wait()
									end
									local si, _ = findGrabSkillIndex()
									if si then
										skill(si)
										task.wait(0.5)
										-- Teleport under map to void-kill grabbed target
										teleportTo(Vector3.new(myPos.X, -5000, myPos.Z))
									else
										-- No grab skill: spam all skills
										for s = 1, 4 do skill(s); task.wait(skillDelay[s]) end
									end
								end
							end
						end
					end)

					-- Wait for threat thread to finish (max 8s)
					local t0 = tick()
					repeat task.wait(0.05) until not coroutine.status or tick()-t0 > 8
					task.cancel(threatThread)

					State.Running = savedRunning
					State.AltThreatBusy = false
					uiStatus("ALT ACTIVE", Color3.fromRGB(139, 92, 246))
					continue
				end
			end

			-- ── Save whitelisted farmer ─────────────────────────────
			if State.AltSaveFarmer then
				for _, wname in ipairs(getResolvedTargets(State.Whitelist)) do
					local fp = Players:FindFirstChild(wname)
					if fp and fp.Character then
						local fhrp = fp.Character:FindFirstChild("HumanoidRootPart")
						if fhrp and fhrp.Position.Y < 0 then
							log("Saving farmer: "..wname,"ALT")
							local si, _ = findGrabSkillIndex()
							if si then
								-- Teleport to farmer, use grab skill, bring to spawn
								teleportFacing(fhrp.Position + Vector3.new(0,3,0), fhrp.Position)
								task.wait(0.1)
								skill(si)
								task.wait(0.5)
								teleportTo(State.AltSpawnPlace)
							else
								-- No grab skill: just teleport farmer's character to spawn
								if fp.Character:FindFirstChild("HumanoidRootPart") then
									fp.Character.HumanoidRootPart.CFrame = CFrame.new(State.AltSpawnPlace)
								end
							end
						end
					end
				end
			end

			-- ── Hit+reset self ──────────────────────────────────────
			if State.AltHitReset then
				local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 and hum.MaxHealth > 0 then
					local pct = hum.Health / hum.MaxHealth
					if pct <= 0.91 then
						log("Alt HP "..math.floor(pct*100).."% → force resetting","ALT")
						while plr.Character and plr.Character:FindFirstChildOfClass("Humanoid") and
							  plr.Character:FindFirstChildOfClass("Humanoid").Health > 0 do
							resetCharacter(); task.wait(0.05)
						end
					end
				end
			end

			-- ── Legacy hit_reset mode (30% threshold) ───────────────
			if State.AttackMode == "hit_reset" then
				local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 and hum.Health < (hum.MaxHealth * 0.3) then
					log("HP < 30% → self-resetting","ALT"); task.wait(0.08); resetCharacter()
				end
			end

			-- ── Stay at spawn ────────────────────────────────────────
			if (myPos - State.AltSpawnPlace).Magnitude > 5 then
				teleportTo(State.AltSpawnPlace)
			end
		end
		log("Alt loop ended."); uiStatus("IDLE", Color3.fromRGB(120, 120, 160))
	end)
	startWatchdog(function() if State.Running then startAltLoop() end end)
	if State.AltAntiVoid then startAltAntiVoid() end
end

stopAltLoop = function()
	State.Running = false
	for _, k in ipairs({"AltThread","WatchdogThread"}) do
		if State[k] then task.cancel(State[k]); State[k] = nil end
	end
	stopAntiAFK(); stopWatchdog(); stopAltAntiVoid()
	log("Alt stopped."); uiStatus("IDLE", Color3.fromRGB(120, 120, 160))
end

