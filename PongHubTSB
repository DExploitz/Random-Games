-- ── Logging & status ─────────────────────────────────────────
local function log(msg, tag)
	local line = "[" .. os.date("%H:%M:%S") .. "]" .. (tag and (" ["..tag.."]") or "") .. " " .. msg
	table.insert(State.LogLines, 1, line)
	if #State.LogLines > 80 then table.remove(State.LogLines) end
	if State.LogCB then pcall(State.LogCB, line, tag) end
	print("[PongHub] " .. msg)
end

local function uiStatus(text, col)
	if State.StatusCB then pcall(State.StatusCB, text, col) end
end

local function sc(fn, ...)
	local ok, err = pcall(fn, ...)
	if not ok then log("err: " .. tostring(err), "ERR") end
	return ok
end

-- ── Helper: find grab-skill (Flowing Water / Lethal Whirlwind Stream) ──
local GRAB_SKILL_NAMES = {'Flowing Water', 'Lethal Whirlwind Stream'}
local function findGrabSkillIndex()
	local bp={}
	for _,t in ipairs(plr.Backpack:GetChildren()) do if t:IsA("Tool") then table.insert(bp,t) end end
	for i,t in ipairs(bp) do
		for _,name in ipairs(GRAB_SKILL_NAMES) do
			if t.Name:find(name,1,true) then return i,t end
		end
	end
	return nil,nil
end

-- ── Combat inputs ─────────────────────────────────────────────
local function m1()
	local a1={Goal="LeftClick"}; local a2={Goal="LeftClickRelease"}
	if IsMobile  then a1.Mobile=true;  a2.Mobile=true  end
	if IsConsole then a1.Console=true; a2.Console=true end
	sc(function() communicate:FireServer(a1) end)
	sc(function() communicate:FireServer(a2) end)
end

local function skill(n)
	local bp={}
	for _,t in ipairs(plr.Backpack:GetChildren()) do if t:IsA("Tool") then table.insert(bp,t) end end
	if not bp[n] then log("Skill "..n.." missing","WARN"); return end
	sc(function() communicate:FireServer({Tool=bp[n],Goal="Console Move"}) end)
end

local function dash()
	sc(function()
		communicate:FireServer({Dash=Enum.KeyCode.W,Key=Enum.KeyCode.Q,Goal="KeyPress"})
		communicate:FireServer({Dash=Enum.KeyCode.W,Key=Enum.KeyCode.Q,Goal="KeyRelease"})
	end)
end

local function awakening()
	sc(function()
		communicate:FireServer({Goal="KeyPress",  Key=Enum.KeyCode.G})
		communicate:FireServer({Goal="KeyRelease",Key=Enum.KeyCode.G})
	end)
end

local function jump()
	sc(function()
		communicate:FireServer({Goal="KeyPress",  Key=Enum.KeyCode.Space})
		communicate:FireServer({Goal="KeyRelease",Key=Enum.KeyCode.Space})
